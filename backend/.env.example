# ── Gmail SMTP ───────────────────────────────────────────────────────────────
# Your Gmail address
GMAIL_USER=you@gmail.com

# Gmail App Password (16 chars, generated at myaccount.google.com → App passwords)
# Do NOT use your regular Gmail password here
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Company Info (used in PDF + emails) ──────────────────────────────────────
COMPANY_NAME=Cleannest
COMPANY_PHONE=(530) 555-0100
COMPANY_EMAIL=hello@cleannest.com
COMPANY_WEBSITE=www.cleannest.com
COMPANY_ADDRESS=Chico, CA

# ── App ──────────────────────────────────────────────────────────────────────
# Public URL of this backend — Vapi uses this to call the tool webhook
# For local dev: use ngrok (https://xxxx.ngrok.io)
# For production: your Railway / Render deployment URL
BASE_URL=https://your-backend.railway.app

# ── Resend (HTTP email API — works on Render free tier) ──────────────────────
# Sign up free at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address shown to customers.
# While testing: onboarding@resend.dev (Resend's free test address, no setup needed)
# For production: verify your own domain in Resend → Domains, then use that address
FROM_EMAIL=onboarding@resend.dev

# Reply-To address — customer replies go HERE (your Gmail inbox)
REPLY_TO_EMAIL=amols.emailid@gmail.com

# ── Company Info (used in PDF + emails) ──────────────────────────────────────
COMPANY_NAME=CleanAI
COMPANY_PHONE=(530) 508-3355
COMPANY_EMAIL=amols.emailid@gmail.com
COMPANY_WEBSITE=www.cleanai.com
COMPANY_ADDRESS=Chico, CA

# ── App ──────────────────────────────────────────────────────────────────────
# Public URL of this backend — Vapi uses this to call the tool webhook
BASE_URL=https://cleanai-0wzp.onrender.com

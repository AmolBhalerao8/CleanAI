# ── Resend (HTTP email API — works on Render free tier) ──────────────────────
# Sign up free at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address shown to customers.
# While testing you can use: onboarding@resend.dev (Resend's test address)
# For production: add your own domain in Resend dashboard → Domains
FROM_EMAIL=onboarding@resend.dev

# ── Company Info (used in PDF + emails) ──────────────────────────────────────
